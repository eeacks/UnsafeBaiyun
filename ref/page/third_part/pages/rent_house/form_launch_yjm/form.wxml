<view class="page">
    <view class="container">
        <view class="box">
            <image src="https://qv1.pinganbaiyun.cn/img/img_012_online_buzi/wellcome_gd_security.png" style="width:100%;height:100%;position:fixed;"></image>
        </view>
    </view>
    <view class="goods-detail-m" wx:if="{{isShowModel_yjm_res}}">
        <view class="mask-m"></view>
        <view class="goodsdetail-m">
            <view style="text-align:center">
                <image src="https://qv1.pinganbaiyun.cn/img/img_005_room/ask.svg" style="width:120rpx;height:120rpx;margin-top:20rpx"></image>
            </view>
            <view class="goodsdetail-m-title">您已申报成功?</view>
            <view class="goodsdetail-m-body">
                <button bindtap="apply_again" class="goodsdetail-m-body-left">申报失败</button>
                <button bindtap="apply_success" class="goodsdetail-m-body-right">申报成功</button>
            </view>
        </view>
    </view>
</view>
