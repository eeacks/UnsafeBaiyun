.takephoto {
    width: 100%
}

.takephoto .camera {
    position: relative
}

.takephoto .camera,.takephoto wx-camera {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center
}

.takephoto wx-camera {
    height: 100%;
    position: absolute;
    width: 100%;
    z-index: -99
}

.takephoto .goBack {
    color: #1792f0;
    font-size: 35rpx;
    margin-left: 35rpx
}

.distinguishing wx-image {
    height: 370rpx;
    width: 100%
}

.progress_bg {
    position: absolute
}

.takephoto .complete {
    background: #fff;
    border-top: 1rpx solid #e5e5e5;
    bottom: 0;
    color: #1792f0;
    font-size: 40rpx;
    height: 100rpx;
    line-height: 100rpx;
    position: fixed;
    text-align: center;
    width: 100%
}
