    text-overflow: ellipsis;
    white-space: nowrap;
    width: auto
}

.weui-tab {
    height: 100%;
    position: relative
}

.weui-tab__panel {
    -webkit-overflow-scrolling: touch;
    box-sizing: border-box;
    height: 100%;
    overflow: auto;
    padding-top: 50px
}

.weui-search-bar {
    background-color: #efeff4;
    border-bottom: 1rpx solid #d7d6dc;
    border-top: 1rpx solid #d7d6dc;
    box-sizing: border-box;
    display: -webkit-box;
    display: -webkit-flex;
    display: flex;
    padding: 8px 10px;
    position: relative
}

.weui-icon-search {
    font-size: inherit;
    margin-right: 8px
}

.weui-icon-search_in-box {
    left: 10px;
    position: absolute;
    top: 7px
}

.weui-search-bar__text {
    display: inline-block;
    font-size: 14px;
    vertical-align: middle
}

.weui-search-bar__form {
    -webkit-box-flex: 1;
    background: #fff;
    border: 1rpx solid #e6e6ea;
    border-radius: 5px;
    -webkit-flex: auto;
    flex: auto;
    position: relative
}

.weui-search-bar__box {
    box-sizing: border-box;
    padding-left: 30px;
    padding-right: 30px;
    position: relative;
    width: 100%;
    z-index: 1
}

.weui-search-bar__input {
    font-size: 14px;
    height: 28px;
    line-height: 28px
}

.weui-icon-clear {
    font-size: 0;
    padding: 7px 8px;
    position: absolute;
    right: 0;
    top: 0
}

.weui-search-bar__label {
    background: #fff;
    border-radius: 3px;
    bottom: 0;
    color: #9b9b9b;
    left: 0;
    line-height: 28px;
    position: absolute;
    right: 0;
    text-align: center;
    top: 0;
    z-index: 2
}

.weui-search-bar__cancel-btn {
    color: #09bb07;
    line-height: 28px;
    margin-left: 10px;
    white-space: nowrap
}
