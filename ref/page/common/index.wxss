.index-hd {
    padding: 80rpx;
    text-align: center
}

.index-bd {
    padding: 0 30rpx 40rpx
}

.index-ft {
    padding-bottom: 20rpx;
    text-align: center
}

.index-logo {
    height: 86rpx;
    width: 86rpx
}

.index-desc {
    color: #888;
    font-size: 28rpx;
    margin-top: 20rpx
}

.navigator-box {
    background-color: #fff;
    font-size: 34rpx;
    line-height: 1.41176471;
    opacity: 0;
    position: relative;
    -webkit-transform: translateY(-50%);
    transform: translateY(-50%);
    transition: .3s
}

.navigator-box-show {
    opacity: 1;
    -webkit-transform: translateY(0);
    transform: translateY(0)
}

.navigator {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    padding: 20rpx 30rpx;
    position: relative
}

.navigator:before {
    border-top: 1rpx solid #d8d8d8;
    color: #d8d8d8;
    content: " ";
    height: 1px;
    left: 30rpx;
    position: absolute;
    right: 30rpx;
    top: 0
}

.navigator:first-child:before {
    display: none
}

.navigator-text {
    -webkit-flex: 1;
    flex: 1
}

.navigator-arrow {
    padding-right: 26rpx;
    position: relative
}

.navigator-arrow:after {
    border-color: #888;
    border-style: solid;
    border-width: 2rpx 2rpx 0 0;
    content: " ";
    display: inline-block;
    height: 18rpx;
    margin-top: -8rpx;
    position: absolute;
    right: 28rpx;
    top: 50%;
    -webkit-transform: matrix(.71,.71,-.71,.71,0,0);
    transform: matrix(.71,.71,-.71,.71,0,0);
    width: 18rpx
}

.kind-list-item {
    background-color: #fff;
    border-radius: 4rpx;
    margin: 20rpx 0;
    overflow: hidden
}

.kind-list-item:first-child {
    margin-top: 0
}

.kind-list-text {
    -webkit-flex: 1;
    flex: 1
}

.kind-list-img {
    height: 60rpx;
    width: 60rpx
}

.kind-list-item-hd {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    padding: 30rpx;
    transition: opacity .3s
}

.kind-list-item-hd-show {
    opacity: .2
}

.kind-list-item-bd {
    height: 0;
    overflow: hidden
}

.kind-list-item-bd-show {
    height: auto
}
