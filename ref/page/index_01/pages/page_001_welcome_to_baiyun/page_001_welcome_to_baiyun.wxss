    right: 60rpx;
    width: 40rpx
}

.content {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column
}

.ch_name {
    font-size: 40rpx;
    font-weight: 600
}

.en_name {
    color: #0a0a0a;
    font-size: 15rpx
}

.described_content,.en_name {
    font-weight: 200;
    margin-top: -10rpx
}

.described_content {
    color: #848484;
    font-size: 30rpx
}

.middle_content {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column
}

.rotate {
    -webkit-transform: rotate(-180deg);
    transform: rotate(-180deg)
}

.rotate,.rotate_back {
    transition: all .8s
}

.first_height_add {
    height: 280rpx;
    transition: height .8s ease
}

.height_add {
    height: 210rpx
}

.height_add,.height_add_back {
    transition: height .8s ease
}

.mini_menu {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    height: 80rpx;
    width: 700rpx
}

.first_menu_box {
    width: 250rpx
}

.first_menu_box,.menu_box {
    background-color: #f7f7f7;
    border-radius: 15rpx;
    font-size: 33rpx;
    height: 60rpx;
    line-height: 60rpx;
    margin-left: 20rpx;
    text-align: center
}

.menu_box {
    width: 150rpx
}

.menu_text {
    color: #2970ed
}

.first_show_menu {
    height: 145rpx;
    line-height: 145rpx
}

.first_show_menu,.show_menu {
    overflow: auto;
    transition: height .8s ease
}

.show_menu {
    height: 60rpx;
    line-height: 60rpx
}

.show_menu_hide {
    height: 0;
    line-height: 0;
    overflow: hidden;
    transition: height .5s ease
}

