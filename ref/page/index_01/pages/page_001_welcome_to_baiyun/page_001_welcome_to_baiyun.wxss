    position: absolute;
    width: 100%
}

.content_box {
    -webkit-flex-direction: column;
    flex-direction: column;
    margin-top: 28vh;
    padding: 0 25rpx;
    position: absolute;
    width: 93vw
}

.content_box,.first_row {
    display: -webkit-flex;
    display: flex
}

.first_row,.row {
    -webkit-align-items: center;
    align-items: center;
    -webkit-flex-direction: row;
    flex-direction: row;
    margin: 10rpx -2rpx
}

.row {
    display: -webkit-flex;
    display: flex
}

.last_row {
    margin-bottom: 40rpx
}

.rzdj {
