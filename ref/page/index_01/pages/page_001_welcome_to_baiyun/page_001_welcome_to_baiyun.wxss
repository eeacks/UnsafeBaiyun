    width: 335rpx
}

.box,.row_box {
    -webkit-align-items: center;
    align-items: center;
    background-color: #fff;
    border-radius: 20rpx;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    height: 130rpx
}

.ls_box,.row_box {
    margin: 30rpx;
    width: 650rpx
}

.ls_box {
    background-color: #fff;
    border-radius: 20rpx;
    height: 130rpx
}

.ls_row {
