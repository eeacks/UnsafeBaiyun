page {
    background-color: #1c90ff;
    overflow: hidden
}

.page {
    height: 100%;
    width: 100%
}

.flex,.flex_row_cc {
    display: -webkit-flex;
    display: flex
}

.flex_row_cc {
    -webkit-align-items: center;
    align-items: center;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.vague::before {
    background-size: cover;
    content: "";
    -webkit-filter: blur(8px);
    filter: blur(8px);
    height: 100%;
    left: 0;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 5
}

.Loading {
    color: #323232;
    font-size: 56rpx;
    font-weight: 700;
    left: 14%;
    position: fixed;
    top: 20%;
    z-index: 6
}

.bg_img {
    height: 100vh;
    width: 100%
}

.title_color {
    color: #848484;
    display: block;
    font-size: 36rpx;
    width: 34%
}

.content_clolr,.content_clolr2 {
    color: #323232;
    display: block;
    font-size: 36rpx
}

.content_clolr2 {
    margin-left: 2%
}

.container {
    left: 12%;
    position: fixed;
    top: 264rpx;
    width: 76%;
    z-index: 3
}

.relative_box {
    -webkit-flex: 1;
    flex: 1;
    position: relative
}

.address_box,.name_box {
    position: absolute;
    width: 100%
}

.address_box {
    margin-top: 20%
}

.time_box {
    position: absolute;
    top: 19%;
    width: 100%
}

.qr_code_box_show {
    left: 21%;
    margin-top: 58%;
