page {
    background: #fff
}

.container_opendoor {
    background: #fff;
    height: 100%;
    width: 100%
}

.itemClass {
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: column;
    flex-direction: column;
    font-size: 32rpx;
    padding: 25rpx
}

.one {
    -webkit-justify-content: space-between;
    justify-content: space-between
}

.one,.two {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row
}

.two {
    margin-top: 20rpx
}

.limitTime {
    -webkit-justify-content: space-between;
    justify-content: space-between;
    margin-top: 20rpx
}

.limit,.limitTime {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row
}

.line {
    background: #eee;
    height: 2rpx;
    margin-top: 30rpx
}

.tagBtn {
    background: #1f90e6;
    border-radius: 8rpx;
    color: #fff;
    font-size: 36rpx;
    font-weight: 700;
    height: 80rpx;
    line-height: 80rpx;
    width: 170rpx
}

.no-login {
    background: rgba(0,0,0,.5);
    bottom: 0;
    -webkit-flex-direction: row;
    flex-direction: row;
    -webkit-justify-content: center;
    justify-content: center;
    left: 0;
    position: fixed;
    right: 0;
    top: 0
}

.no-login,.no-login-content {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex
}

.no-login-content {
    background: #fff;
    border-radius: 10rpx;
    -webkit-flex-direction: column;
    flex-direction: column;
    height: 500rpx;
    width: 600rpx
}

.no-login-content wx-image {
    height: 150rpx;
    margin-top: 42rpx;
    width: 150rpx
}

.hasNoAuth {
    color: gray;
    margin-top: 200rpx;
    text-align: center
}

.guard-count {
    color: #1f90e6;
    font-weight: 700;
    margin-bottom: 5rpx;
    padding-right: 25rpx;
    padding-top: 10rpx;
    text-align: right
}

.extra-info {
    border-top: 1px solid #ddd;
    margin-left: 30rpx;
    overflow: auto;
    padding: 20rpx 0
}

.search-outer {
    background-color: #efeff4;
    border-bottom: 1px solid #ddd;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    height: 40px;
    overflow: hidden;
    padding: 8px
}

.search-input {
    background-color: #fff;
    border-color: transparent;
    color: #000;
    display: block;
    -webkit-flex: 1;
    flex: 1;
    font-size: 15px;
    height: 24px;
    text-align: left
}

.search-input:focus + .search-cancel {
    margin-right: 0;
    opacity: 1
}

.search-cancel {
    color: #108ee9;
    display: inline-block;
    font-size: 16px;
    height: 24px;
    line-height: 24px;
    margin-right: -40px;
    opacity: 0;
    padding-left: 8px;
    text-align: right;
    transition: margin-right .3s,opacity .3s;
    transition-delay: .1s
}

.big-m {
    bottom: 0;
    -webkit-flex-direction: row;
    flex-direction: row;
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    z-index: 999
}

.big-m,.vis-show {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    -webkit-justify-content: center;
    justify-content: center
}

.vis-show {
    background: rgba(0,0,0,.8);
    border-radius: 50rpx;
    -webkit-flex-direction: column;
    flex-direction: column;
    position: relative
}

.vis-show wx-image {
    height: 250rpx;
    margin-bottom: 20rpx;
    width: 280rpx
}

.vis-text {
    bottom: 32rpx;
    color: #fff;
    font-size: 28rpx;
    position: absolute
}

.can-open {
    color: #5a5a5a;
    font-size: 31rpx
}

.cannot-open {
    color: #b88a00;
    font-size: 31rpx
}

.out_date {
    color: red;
    font-size: 31rpx
}
