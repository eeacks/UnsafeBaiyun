.weui-half-screen-dialog {
    background-color: #fff;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    bottom: 0;
    left: 0;
    line-height: 1.4;
    max-height: 75%;
    overflow: hidden;
    padding: 0;
    position: fixed;
    right: 0;
    z-index: 5000
}

.weui-half-screen-dialog__hd {
    -webkit-align-items: center;
    align-items: center;
    display: -webkit-flex;
    display: flex;
    font-size: 8px;
    height: 8em
}

.weui-half-screen-dialog__hd .weui-icon-btn {
    position: absolute;
    top: 50%;
    -webkit-transform: translateY(-50%);
    transform: translateY(-50%)
}

.weui-half-screen-dialog__hd__side {
    left: -8px;
    position: relative
}

.weui-half-screen-dialog__hd__main {
    -webkit-flex: 1;
    flex: 1
}

.weui-half-screen-dialog__hd__side+.weui-half-screen-dialog__hd__main {
    padding: 0 40px;
    text-align: center
}

.weui-half-screen-dialog__hd__main+.weui-half-screen-dialog__hd__side {
    left: auto;
    right: -8px
}

.weui-half-screen-dialog__hd__main+.weui-half-screen-dialog__hd__side .weui-icon-btn {
    right: 0
}

.weui-half-screen-dialog__title {
    color: rgba(0,0,0,.9);
    display: block;
    font-size: 15px;
    font-weight: 700
}

.weui-half-screen-dialog__subtitle {
    color: rgba(0,0,0,.5);
    display: block;
    font-size: 10px
}

.weui-half-screen-dialog__bd {
    word-wrap: break-word;
    -webkit-hyphens: auto;
    hyphens: auto;
    overflow-y: auto
}

.weui-half-screen-dialog__desc {
    color: rgba(0,0,0,.9);
    font-size: 17px;
    font-weight: 700;
    line-height: 1.4;
    padding-top: 4px
}

.weui-half-screen-dialog__tips {
    color: rgba(0,0,0,.3);
    font-size: 14px;
    line-height: 1.4;
    padding-top: 16px
}

.weui-half-screen-dialog__ft {
    padding: 0 24px 32px;
    text-align: center
}

.weui-half-screen-dialog__ft .weui-btn:nth-last-child(n+2),.weui-half-screen-dialog__ft .weui-btn:nth-last-child(n+2)+.weui-btn {
    display: inline-block;
    margin: 0 8px;
    vertical-align: top;
    width: 120px
}

.weui-icon-btn {
    background-color: initial;
    background-position: 50% 50%;
    background-repeat: no-repeat;
    background-size: 100%;
    border: 0;
    font-size: 0;
    outline: 0
}

