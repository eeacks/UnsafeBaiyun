<view class="page">
    <view class="bd">
        <view class="bd-content">
            <view style="height:50%;">
                <view style="display:flex;flex-direction:row;align-items:center;justify-content:center;margin-top:40rpx;color:#323232;">
                    <text style="margin-right:24rpx;">{{address}}</text>
                    <text>{{room_name}}</text>
                    <text>{{garden_name}}</text>
                </view>
                <view style="display:flex;flex-direction:column;justify-content:center;margin-top:3vh;color:black;">
                    <view style="text-align:center;">所在社区：<text style="margin-right:12px;">{{street_name}}</text>
                        <text>{{community}}</text>
                    </view>
                </view>
                <view>
                    <button bindtap="go_paby_check_in" style="color:#FFFFFF;width:490rpx;height:85rpx;font-size:34rpx;text-align:center;box-shadow:-3rpx 20rpx 30rpx -15rpx #318CFF;" type="primary">点击入住登记</button>
                </view>
            </view>
        </view>
        <view class="bottom-content">
            <view style="height:280rpx;display:flex;flex-direction:row;align-items:center;justify-content:space-around;color:#1582FF;font-size:36rpx;font-weight:bold;background-color:#ffffff;border:20rpx;border-radius:25rpx;">
                <view bindtap="go_pass" style="display:flex;flex-direction:column;">
                    <image src="https://qv1.pinganbaiyun.cn/img/img_004_index/hd_lfdj.svg" style="height:150rpx;width:150rpx;margin-bottom:12rpx;"></image>
                    <view>来访登记</view>
                </view>
                <view bindtap="go_city_manage" style="display:flex;flex-direction:column;">
                    <image src="https://qv1.pinganbaiyun.cn/img/img_004_index/hd_zhcg.svg" style="height:150rpx;width:150rpx;margin-bottom:12rpx;"></image>
                    <view>智慧城管</view>
                </view>
                <view bindtap="go_search_house" style="display:flex;flex-direction:column;">
                    <image src="https://qv1.pinganbaiyun.cn/img/img_004_index/hd_byezf.svg" style="height:150rpx;width:150rpx;margin-bottom:12rpx;"></image>
                    <view>白云e租房</view>
                </view>
            </view>
        </view>
        <view style="color:black;font-weight:bold;text-align:center;position:absolute;bottom:30rpx;left:0;right:0;height:35rpx;">{{attribute_recid_code}}</view>
    </view>
    <view class="goods-detail-m" wx:if="{{isShowModel_yjm_res}}">
        <view class="mask-m"></view>
        <view class="goodsdetail-m">
            <view style="text-align:center">
                <image src="https://qv1.pinganbaiyun.cn/img/img_005_room/ask.svg" style="width:120rpx;height:120rpx;margin-top:20rpx"></image>
            </view>
            <view class="goodsdetail-m-title">您已入住登记成功?</view>
            <view class="goodsdetail-m-body">
                <button bindtap="check_in_again" class="goodsdetail-m-body-left">登记失败</button>
                <button bindtap="go_subscribe" class="goodsdetail-m-body-right">登记成功</button>
            </view>
        </view>
    </view>
    <mp-halfScreenDialog bindbuttontap="buttontap_send_msg" buttons="{{buttons_send_msg}}" maskClosable="{{false}}" show="{{show_ask_send_msg}}" subTitle="" tips="">
        <view slot="title">申请入住成功</view>
        <view slot="desc" style="height:400rpx;">
            <view style="text-align:center;">
                <image src="https://qv1.pinganbaiyun.cn/img/img_005_room/check.svg" style="width:75px;height:75px;"></image>
            </view>
            <view style="margin-left:20px;margin-top:20px;">{{show_success_info}}</view>
            <view style="margin-left:20px;margin-buttom:20px;">您是否允许平安码丨平安白云</view>
            <view style="margin-left:20px;margin-buttom:20px;">为您发送申请结果消息?</view>
        </view>
    </mp-halfScreenDialog>
    <view class="mask" wx:if="{{show_letter}}">
        <view catchtouchmove="check_touch" class="modal-content">
            <view class="modal-title">
                <view class="modal-notice-title">白云公安致辖区居民的一封信</view>
                <view class="modal-notice-date">2022年01月17日</view>
            </view>
            <scroll-view scrollY bindscrolltolower="check_is_read" catchtouchmove="check_touch" class="main-content">
                <view class="modal-content-001">尊敬的居民朋友：<text style="display:inline-block;width:80rpx"></text>欢迎您来到宜居宜商的广州市白云区工作、生活和旅游。当前，白云公安正在开展平安码丨平安白云和安全文明小区建设，竭力为全区提供平安和谐的居住环境。希望您在白云期间，自觉遵守国家法律法规，警民同心共创美丽、和谐的平安码丨平安白云。 一、如实房屋租赁备案。自房屋租赁签订或居住之日起三个工作日内，通过“平安码丨平安白云”小程序登记租赁房屋信息，不登记或不如实登记的，将依法予以行政处罚。 二、坚决远离黄赌毒。不参与任何黄赌毒等违法犯罪活动，不以任何形式为违法犯罪提供条件，一经发现，公安机关将严厉处罚！ 三、妥善处理矛盾纠纷。处理邻里纠纷、家庭矛盾、感情纠纷时，多一些宽容和理解，小不忍则乱大谋！对打架斗殴、故意伤害、持刀打斗的行为，公安机关将严厉追责！ <text style="display:inline-block;"></text>广州市公安局白云区公安分局 2022年01月17日</view>
            </scroll-view>
            <view class="modal-btn-wrapper">
                <view bindtap="confirm_notice" class="confirm-btn" wx:if="{{is_read}}">已阅</view>
                <view class="confirm-btn" wx:if="{{!is_read}}">请滑动完成阅读</view>
            </view>
        </view>
    </view>
    <mp-halfScreenDialog class="show_ld" show="{{show_garden_building}}">
        <view slot="title">{{garden_name}}</view>
        <view slot="desc">
            <view style="display:flex;">
                <image class="shuxian" src="./shuxian.png"></image>
                <view style="display:flex;align-items:center;">{{garden_full_street}}</view>
            </view>
            <view style="margin-top:20rpx;">
                <view class="search">
                    <icon style="margin-left:25rpx;align-items:center;display:flex;" type="search"></icon>
                    <input bindblur="bindblur_garden_building" bindinput="bindinput_garden_building" placeholder="可输入地址搜索" style="display:flex;margin-top:13rpx;margin-left:35rpx;width:250rpx;" value="{{key_word_garden_building}}"></input>
                </view>
            </view>
            <view style="height:40vh;">
                <scroll-view bindscrolltolower="flashlist" scrollY="true" style="height:40vh;position:fixed;margin-top:0rpx;">
                    <view bindtap="select_garden_building" class="card {{itemIndex_garden_building==item.rent_house_rec_id?'on':''}}" data-item="{{item}}" wx:for="{{garden_building_list}}" wx:key="index">
                        <image class="choose_icon" src="./selcet.svg" wx:if="{{itemIndex_garden_building==item.rent_house_rec_id}}"></image>
                        <view class="mpdzmc">{{item.addr_mp}}</view>
                        <view class="full_address">{{item.addr_gz}}</view>
                    </view>
                </scroll-view>
            </view>
            <button bindtap="submit_garden_building" class="submit_button" wx:if="{{!garden_visit_show}}">确定</button>
            <view wx:if="{{garden_visit_show}}">
                <view class="search go_where" style="display:flex;">
                    <image class="shuxian" src="./shuxian.png"></image>
                    <view style="display:flex;align-items:center;">请输入具体去向</view>
                </view>
                <view class="search go_where">
                    <input bindblur="bindblur_garden_room" bindinput="bindblur_garden_room" placeholder="请输入具体去向" style="display:flex;margin-top:13rpx;margin-left:35rpx;width:100%;" value="{{key_word_garden_room}}"></input>
                </view>
            </view>
            <button bindtap="garden_building_visit" class="submit_button" wx:if="{{garden_visit_show}}">确定</button>
        </view>
    </mp-halfScreenDialog>
</view>
