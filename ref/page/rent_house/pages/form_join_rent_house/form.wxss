    width: 100%
}

.nav_left {
    background: #f2f2f2;
    height: 100%;
    left: 0;
    position: absolute;
    text-align: center;
    top: 0;
    width: 25%
}

.nav_left .nav_left_items {
    font-size: 28rpx;
    height: 100rpx;
    line-height: 100rpx
}

.nav_left .nav_left_items.active {
    background: #fff;
    color: #4a8eff;
    position: relative
}

.nav_left .nav_left_items.active::before {
    background: #4a8eff;
    content: "";
    display: inline-block;
    height: 60rpx;
    left: 0;
    position: absolute;
    top: 20rpx;
    width: 6rpx
}

.nav_right {
    height: 100%;
    position: absolute;
    right: 0;
    top: 0;
    width: 75%
}

.nav_right .nav_right_items {
    float: left;
    padding: 30rpx 0;
    text-align: center;
    width: 33.33%
}

.nav_right .nav_right_items wx-image {
    height: 120rpx;
    width: 120rpx
}

.nav_right .nav_right_items wx-text {
    display: block;
    font-size: 28rpx;
    margin-top: 20rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap
}

.nocate {
    padding: 100rpx;
    text-align: center
}

.nocate wx-image {
    height: 70rpx;
    width: 70rpx
}

.nocate wx-text {
