@import "../../../common/lib/weui.wxss";

wx-label {
    display: inline-block;
    margin-right: 20rpx;
    min-width: 270rpx
}

wx-form {
    width: 100%
}

.picker-text {
    margin-left: 20rpx;
    position: relative
}

.modal-mask {
    background: #000;
    color: #fff;
    height: 100%;
    opacity: .5;
    top: 0;
    width: 100%;
    z-index: 9000
}

.modal-dialog,.modal-mask {
    left: 0;
    overflow: hidden;
    position: fixed
}

.modal-dialog {
    background: #f9f9f9;
    border-radius: 10rpx;
    margin: -180rpx 105rpx;
    top: 40%;
    width: 540rpx;
    z-index: 9999
}

.modal-title {
    padding-top: 50rpx
}

.modal-title,.modal-title_01 {
    color: #030303;
    font-size: 36rpx;
    text-align: center
}

.modal-title_01 {
    padding: 0rpx 32rpx 5rpx
}

.modal-content {
    padding: 0rpx 50rpx 30rpx
}

.modal-input {
    display: -webkit-flex;
    display: flex
}

.input {
    box-sizing: border-box;
    color: #333;
    font-size: 28rpx;
    height: 82rpx;
    line-height: 28rpx;
    padding: 0 20rpx;
    width: 100%
}

wx-input-holder {
    color: #666;
    font-size: 28rpx
}

.modal-footer {
    border-top: 1px solid #dedede;
    display: -webkit-flex;
    display: flex;
    -webkit-flex-direction: row;
    flex-direction: row;
    font-size: 34rpx
}

.btn-cancel {
    border-right: 1px solid #dedede;
    color: #666
}

.btn-cancel,.btn-confirm {
    text-align: center;
    width: 50%
}

.btn-confirm {
    color: #ec5300
}

.modal_button {
    margin-bottom: 40rpx;
    margin-top: 40rpx
}

.index-hd {
    padding: 80rpx;
    text-align: center
}

.index-bd {
    padding: 0 30rpx 40rpx
}

.index-ft {
    padding-bottom: 20rpx;
    text-align: center
}

.index-logo {
    height: 86rpx;
    width: 86rpx
}

.index-desc {
    color: #888;
    font-size: 28rpx;
    margin-top: 20rpx
}
